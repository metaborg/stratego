                            [SOpt(HS(), "0")]
                          , [S("$IntOrID")]
                          )
                        ]

  is-RV32IM-IntOrID =
    ?IntOrID-Plhdr(_)

  prettyprint-RV32IM-Instruction :
    Instruction-Plhdr(_) -> [ H(
                                [SOpt(HS(), "0")]
                              , [S("$Instruction")]
                              )
                            ]

  is-RV32IM-Instruction =
    ?Instruction-Plhdr(_)

  prettyprint-RV32IM-ID :
    ID-Plhdr(_) -> [ H(
                       [SOpt(HS(), "0")]
                     , [S("$ID")]
                     )
                   ]

  is-RV32IM-ID =
    ?ID-Plhdr(_)

  prettyprint-RV32IM-Line :
    Line-Opt-Plhdr() -> [ H(
                            []
                          , [S("")]
                          )
                        ]

  is-RV32IM-Line =
    ?Line-Opt-Plhdr()

  prettyprint-RV32IM-INT :
    INT-Opt-Plhdr() -> [ H(
                           []
                         , [S("")]
                         )
                       ]

  is-RV32IM-INT =
    ?INT-Opt-Plhdr()

  prettyprint-RV32IM-IntOrID :
    IntOrID-Opt-Plhdr() -> [ H(
                               []
                             , [S("")]
                             )
                           ]

  is-RV32IM-IntOrID =
    ?IntOrID-Opt-Plhdr()