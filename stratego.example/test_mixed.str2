module test_mixed
imports libstratego-lib

signature
  constructors
    Car1  : a             -> List(a)
    Car2  : a             -> List(a)

strategies
  uncar2 = match sequential
             case | Car1(_): Cons(!1, Nil())
             case | Car2(_): Cons(!2, Nil())
             case | "abc" when ?"something": !"cba"
             case | "abc" when ?"somethingelse": !"abc"
             case | a: !"a"
             case | b: !"b"
             case | _: !"string?"
             case | 8: !54
             case | 5.4: !8
           end
